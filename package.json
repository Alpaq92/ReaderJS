{
  "name": "preview-js",
  "version": "1.0.0",
  "description": "Client-side universal document viewer — PDF, DjVu, ODF, Office, e-books, comics and images — permissive, no server, no upload",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:embed:app": "vite build --config vite.config.app.js",
    "build:embed:loader": "vite build --config vite.config.embed.js",
    "build:embed": "npm run build:embed:app && npm run build:embed:loader",
    "preview": "vite preview",
    "docs": "jsdoc src -r -d docs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chmate": "github:Alpaq92/CHMate#86b26bb8c33255de89db4fa68e610b9ac7cc286a",
    "dejaview": "github:Alpaq92/dejaview#ae7aed28a7e9f1ef9658d421471ffb66336ada09",
    "diff": "^9.0.0",
    "exifr": "^7.1.3",
    "foliate-js": "github:johnfactotum/foliate-js#78914aef4466eb960965702401634c2cb348e9b1",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "libarchive.js": "^2.0.2",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "mhtml-to-html": "^2.0.1",
    "papaparse": "^5.5.4",
    "pdfjs-dist": "^6.1.200",
    "pptxviewjs": "^1.1.9",
    "riposte": "github:Alpaq92/Riposte#307ef7dfd9c5e8c0c07a840874e013cf94a85ada",
    "rtf.js": "^3.0.9",
    "utif": "^3.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "vite": "^8.1.2"
  }
}
