{
  "name": "preview-js",
  "version": "1.0.0",
  "description": "Client-side universal document viewer — PDF, DjVu, ODF, Office, e-books, comics and images — permissive, no server, no upload",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:embed:app": "vite build --config vite.config.app.js",
    "build:embed:loader": "vite build --config vite.config.embed.js",
    "build:embed": "npm run build:embed:app && npm run build:embed:loader",
    "preview": "vite preview",
    "docs": "jsdoc src -r -d docs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "dejaview": "github:Alpaq92/dejaview#5a4ef8a81c5efb8942ae8f11a61172bd91a908ff",
    "exifr": "^7.1.3",
    "foliate-js": "github:johnfactotum/foliate-js#78914aef4466eb960965702401634c2cb348e9b1",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "libarchive.js": "^2.0.2",
    "mammoth": "^1.8.0",
    "marked": "^18.0.5",
    "papaparse": "^5.5.4",
    "pdfjs-dist": "^4.9.155",
    "pptxviewjs": "^1.1.9",
    "rtf.js": "^2.2.0",
    "utif": "^3.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "vite": "^6.0.7"
  }
}
