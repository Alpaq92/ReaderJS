{
  "name": "preview-js",
  "version": "1.0.0",
  "description": "Universal document viewer: PDF, ODF, RTF, DOCX — powered by pdf.js, WebODF, rtf.js and docx submodules",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:embed:app": "vite build --config vite.config.app.js",
    "build:embed:loader": "vite build --config vite.config.embed.js",
    "build:embed": "npm run build:embed:app && npm run build:embed:loader",
    "preview": "vite preview",
    "submodules:init": "git submodule update --init --recursive",
    "docs": "jsdoc src -r -d docs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "exifr": "^7.1.3",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "libarchive.js": "^2.0.2",
    "mammoth": "^1.8.0",
    "marked": "^18.0.5",
    "papaparse": "^5.5.4",
    "pdfjs-dist": "^4.9.155",
    "pptxviewjs": "^1.1.9",
    "rtf.js": "^2.2.0",
    "utif": "^3.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "vite": "^6.0.7"
  }
}
